############################################################
# SQL Server 连接配置示例
# 复制本文件为 .env，然后填写你自己的数据库连接信息
############################################################

# 后端服务端口
PORT=3001

# SQL Server 服务器地址（如：localhost 或 192.168.1.10）
DB_SERVER=localhost

# 数据库名称
DB_DATABASE=ERP

# SQL Server 登录（SQL 认证）：必须同时配置账号与密码
# 说明：Windows 集成认证需要额外驱动（如 mssql/msnodesqlv8），本项目默认按 SQL 登录连接
DB_USER=sa
DB_PASSWORD=your_password

# 端口（默认 1433）
DB_PORT=1433

# 是否启用加密连接（encrypt）
# - 如果你遇到 “ERR_SSL_UNSUPPORTED_PROTOCOL / unsupported protocol” 报错，通常设置为 false 即可
DB_ENCRYPT=false

# 是否信任服务器证书（本地开发常用 true；生产环境请按实际证书配置）
DB_TRUST_SERVER_CERTIFICATE=true

# ------------------------------------------------------------
# 可选：Playwright 部门新增冒烟（scripts/e2e-dept-office.mjs）
# 仅填本机测试账号，勿把真实生产密码提交到 git
# ------------------------------------------------------------
# E2E_USERCODE=你的工号
# E2E_PASSWORD=你的密码
# 若 Vite 不在 5173（端口被占用时常见 5174）：
# PLAYWRIGHT_BASE_URL=http://localhost:5174

# ------------------------------------------------------------
# 纸格资料：Excel 上传落盘与旧库文件下载根目录（可相同）
# 本地测试示例（请按本机路径修改）：
# PAPER_PATTERN_UPLOAD_DIR=C:\Users\it_manager\Desktop\纸格测试资料\upload
# PAPER_PATTERN_DOWNLOAD_ROOT=C:\Users\it_manager\Desktop\纸格测试资料\upload
# 未配置时服务端默认同上路径；上线改为服务器共享目录即可
# ------------------------------------------------------------
# PAPER_PATTERN_UPLOAD_DIR=
# PAPER_PATTERN_DOWNLOAD_ROOT=
# SYSTEM_UPLOAD_FILE_TABLE=System_uplod_file

